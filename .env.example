# Copy to .env and adjust. NEVER commit real secrets.

# --- Core (all optional; sensible defaults are built in) ---
WC2026_SEED=20260611              # global random seed (reproducibility)
WC2026_N_SIMS=50000               # Monte Carlo simulations per run

# --- API ---
# Bearer token required to call POST /api/admin/* (ingest, train).
# If unset, admin endpoints return 503 (disabled).
WC2026_ADMIN_TOKEN=
WC2026_CORS_ORIGINS=*             # comma-separated origins for the browser app

# --- Database (only needed for the relational persistence path / docker) ---
# Docker Compose sets this automatically. Locally you can use SQLite, e.g.:
#   DATABASE_URL=sqlite:////tmp/wc2026.db
DATABASE_URL=postgresql+psycopg2://wc2026:wc2026@localhost:5432/wc2026

# --- Frontend (baked at build time) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional external data providers (real sources; demo works without them) ---
# football-data.org API token to enable the alternative results adapter.
FOOTBALL_DATA_API_KEY=
