# Raw data: keep the source feeds committed so the World Cup fixture schedule
# survives a clean checkout and the auto-update merge can preserve it (the live
# feed only carries played matches). Interim scratch stays ignored.
data/raw/*
!data/raw/results.csv
!data/raw/goalscorers.csv
!data/raw/shootouts.csv
data/interim/

